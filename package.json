{
  "name": "commission-reporting-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Read-only commission reporting API for Finance",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration"
  },
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.17.10",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
